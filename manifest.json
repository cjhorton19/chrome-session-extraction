{
  "manifest_version": 3,
  "name": "Session Recorder",
  "version": "1.0.0",
  "description": "Records browser actions (navigations, clicks, inputs) and exports them as structured JSON for AI-driven automation scripting.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Session Recorder"
  }
}
